{
  "name": "space-router",
  "description": "All the routing essentials.",
  "version": "0.9.5",
  "main": "dist/cjs",
  "module": "dist/esm",
  "types": "./index.d.ts",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git://github.com/KidkArolis/space-router.git"
  },
  "keywords": [
    "browser",
    "router",
    "small",
    "clientside",
    "universal",
    "history",
    "location",
    "url"
  ],
  "engines": {
    "node": ">=14"
  },
  "author": "Karolis Narkevicius",
  "scripts": {
    "test": "npm run build && oxlint -c oxlintrc.json && oxfmt --check '**/*.{js,css,yml}' && c8 ava",
    "format": "oxfmt --write '**/*.{js,css,yml}'",
    "coverage": "c8 --reporter=html ava",
    "build": "node ./tasks/build.js",
    "watch": "node ./tasks/build.js -w",
    "release": "np --no-release-draft",
    "release:beta": "np --tag=beta --no-release-draft",
    "release:docs": "hugo -s docs && gh-pages -d docs/public"
  },
  "devDependencies": {
    "@swc-node/register": "^1.11.1",
    "@swc/cli": "^0.8.1",
    "@swc/core": "^1.15.30",
    "ava": "^7.0.0",
    "c8": "^11.0.0",
    "execa": "^9.6.1",
    "gh-pages": "^6.3.0",
    "oxfmt": "^0.46.0",
    "oxlint": "^1.61.0"
  },
  "ava": {
    "require": [
      "@swc-node/register"
    ]
  },
  "overrides": {
    "minimatch": ">=10.2.1"
  }
}
